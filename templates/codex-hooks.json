{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "^Bash$",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$(git rev-parse --show-toplevel)/.dev-discipline/adapter/codex/hooks/pre-bash.sh\"",
            "timeout": 120,
            "statusMessage": "Checking dev-discipline Bash policy"
          }
        ]
      },
      {
        "matcher": "^apply_patch$|Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$(git rev-parse --show-toplevel)/.dev-discipline/adapter/codex/hooks/pre-edit.sh\"",
            "timeout": 10,
            "statusMessage": "Checking dev-discipline edit policy"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$(git rev-parse --show-toplevel)/.dev-discipline/adapter/codex/hooks/stop.sh\"",
            "timeout": 10,
            "statusMessage": "Checking dev-discipline session policy"
          }
        ]
      }
    ]
  }
}
